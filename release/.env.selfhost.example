# Raphael self-hosted release — copy to .env and customize
RAPHAEL_VERSION=0.1.0
RAPHAEL_REGISTRY=ghcr.io/hblabs

# Build from sibling repos instead of pulling registry images (use when GHCR images are unavailable)
RAPHAEL_BUILD_LOCAL=0

# Required
POSTGRES_PASSWORD=change-me-in-production
RAPHAEL_JWT_SECRET=change-me-use-at-least-32-random-bytes!!
RAPHAEL_DATABASE_URL=postgresql://raphael:${POSTGRES_PASSWORD}@postgres:5432/raphael

# Public URL (used in emails and checkout redirects)
RAPHAEL_PUBLIC_API_BASE=http://localhost:5173
RAPHAEL_UI_PORT=5173

# Optional — connect to Raphael Cloud for billing + managed compute (RWU sync)
RAPHAEL_CLOUD_API_KEY=
RAPHAEL_CLOUD_PLAN=team
RAPHAEL_CLOUD_ORG_NAME=

# Optional — Stripe (only when cloud-connected billing is enabled)
RAPHAEL_STRIPE_SECRET_KEY=
RAPHAEL_STRIPE_WEBHOOK_SECRET=

# Optional — transactional email (password reset). Leave empty to show "email not configured".
RAPHAEL_NOTIFICATIONS_POSTMARK_TOKEN=
RAPHAEL_NOTIFICATIONS_FROM_EMAIL=notifications@raphael.app

# Release hardening
RAPHAEL_RELEASE=1
RAPHAEL_DEPLOYMENT_MODE=self_hosted
RAPHAEL_KAFKA_DISABLED=0
RAPHAEL_RWU_DAILY_LIMIT=500
