# Gateway
RAPHAEL_CORE_PORT=8080
RAPHAEL_CORE_HOST=0.0.0.0

# Upstream services (docker compose service names or localhost)
RAPHAEL_IDENTITY_URL=http://localhost:8081
RAPHAEL_ORGS_URL=http://localhost:8082
RAPHAEL_WORKSPACES_URL=http://localhost:8083
RAPHAEL_REVIEWS_URL=http://localhost:8087
RAPHAEL_AUTOMATION_URL=http://localhost:8095
RAPHAEL_CONNECTORS_URL=http://localhost:8096
RAPHAEL_NOTIFICATIONS_URL=http://localhost:8090
RAPHAEL_AUDIT_URL=http://localhost:8093
RAPHAEL_GRAPH_URL=http://localhost:8100
RAPHAEL_SYNC_URL=http://localhost:8098
RAPHAEL_OPS_URL=http://localhost:8103
RAPHAEL_RWU_URL=http://localhost:8101
RAPHAEL_AI_URL=http://localhost:8104
RAPHAEL_ADMIN_URL=http://localhost:8106
RAPHAEL_ARTIFACTS_URL=http://localhost:8107

RAPHAEL_ANALYTICS_URL=http://localhost:8105
RAPHAEL_COMMENTS_URL=http://localhost:8088
RAPHAEL_MESSAGING_URL=http://localhost:8089
RAPHAEL_LINKS_URL=http://localhost:8091
RAPHAEL_REGISTRY_URL=http://localhost:8097
RAPHAEL_ENVIRONMENTS_URL=http://localhost:8102

# Workspace Intelligence — Gemma via Ollama (set stub for CI without GPU)
RAPHAEL_MODEL_BACKEND=ollama
RAPHAEL_OLLAMA_URL=http://localhost:11434
# Default open-weights model pulled by ollama-init on first Docker boot (~2–5 min)
RAPHAEL_GEMMA_MODEL=gemma2:2b
RAPHAEL_MODEL_TIMEOUT_SEC=60
RAPHAEL_MODEL_STARTUP_WAIT_SEC=300

# Legacy Calliope monolith (optional fallback during migration)
RAPHAEL_LEGACY_CALLIOPE_URL=http://localhost:8742

# Event bus
RAPHAEL_KAFKA_BROKERS=localhost:19092

# Notifications — Postmark (no custom SMTP)
RAPHAEL_NOTIFICATIONS_POSTMARK_TOKEN=
RAPHAEL_NOTIFICATIONS_FROM_EMAIL=notifications@raphael.app

# Twilio — SMS alerts + Conversations messaging
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_CONVERSATIONS_SERVICE_SID=

# Stripe — billing (admin service)
RAPHAEL_STRIPE_SECRET_KEY=
RAPHAEL_STRIPE_WEBHOOK_SECRET=
RAPHAEL_STRIPE_PRICE_TEAM=
RAPHAEL_STRIPE_PRICE_ENTERPRISE=

# Object store
RAPHAEL_MINIO_ENDPOINT=localhost:9000
RAPHAEL_MINIO_ACCESS_KEY=raphael
RAPHAEL_MINIO_SECRET_KEY=raphaeldev

# Postgres
RAPHAEL_DATABASE_URL=postgresql://raphael:raphael@localhost:5432/raphael

# JWT (identity service)
RAPHAEL_JWT_SECRET=dev-secret-with-32-byte-minimum-length!!

# Auth0 — enterprise SSO (UI: VITE_* ; gateway: AUTH0_DOMAIN + AUTH0_API_AUDIENCE)
AUTH0_DOMAIN=
AUTH0_API_AUDIENCE=
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
